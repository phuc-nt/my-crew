# Copy to my-crew.env (same directory, gitignored). Compose injects these as process
# env — they win over the wizard-written /data/.env (load_dotenv never overrides).
#
# REQUIRED before first `docker compose up` (R3: binding 0.0.0.0 without auth is
# refused at startup):
#   WEB_AUTH_PASSWORD_HASH ← docker compose run --rm --no-deps my-crew my-crew web hash-password
#   WEB_SESSION_SECRET     ← openssl rand -hex 32
WEB_AUTH_PASSWORD_HASH=
WEB_SESSION_SECRET=

# LLM provider (everything else can be configured later in the browser Setup Wizard).
OPENROUTER_API_KEY=

# Safety defaults — identical to config.example.env.
DRY_RUN=true
TRUST_MODE=autonomous
MONTHLY_BUDGET_USD=50
