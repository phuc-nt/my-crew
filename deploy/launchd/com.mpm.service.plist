<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mpm.service</string>
    <!-- The coordinating service: reads registry.yaml + each profile's schedule (cron),
         spawns per-agent worker subprocesses when reports are due. Replaces the three
         legacy per-report jobs (com.mpm.report.{daily,weekly,resource}.plist) — unload
         those after loading this one (see LEGACY.md) to avoid double-scheduling. -->
    <!-- Use `uv run` (absolute path; launchd PATH is minimal) so the venv is resolved
         the same way as run-report.sh, instead of hardcoding .venv/bin/python. -->
    <key>ProgramArguments</key>
    <array>
        <string>__UV_BIN__</string>
        <string>run</string>
        <string>python</string>
        <string>-m</string>
        <string>my_crew.runtime.service</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__REPO_DIR__</string>
    <!-- launchd starts jobs with a minimal PATH (/usr/bin:/bin:/usr/sbin:/sbin) that
         does NOT include Homebrew or Docker Desktop. Workers spawned by this service
         shell out to `node` (the MCP servers), `docker` (the deep_agent sandbox), `gh`,
         and `gws`; without those dirs on PATH they fail with "No such file or directory".
         The installer renders __BIN_PATH__ from the actual locations of those binaries. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__BIN_PATH__</string>
    </dict>
    <!-- Start at load and restart on crash: the service is meant to run continuously. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__REPO_DIR__/.data/service.log</string>
    <key>StandardErrorPath</key>
    <string>__REPO_DIR__/.data/service.err.log</string>
</dict>
</plist>
